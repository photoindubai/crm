# Public — exposed to the browser (safe for NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Canonical site URL (Vercel deployment or custom domain), used for links and Supabase Auth redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — never expose to the client or prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional server-only name for SSR/middleware if you do not want to use NEXT_PUBLIC_SUPABASE_ANON_KEY locally.
# SUPABASE_ANON_KEY=your-anon-key

# Optional: local scripts / tooling only (import scripts fall back to NEXT_PUBLIC_SUPABASE_URL if unset).
# SUPABASE_URL=
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_DB_URL=
